generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  settings    Json?
  password    String
  createdAt   DateTime @default(now())

  websites    Website[]
  subscriptions Subscription[]
}

model Website {
  id          String   @id @default(cuid())
  name        String
  domain      String
  siteKey     String   @unique
  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  events      Event[]
  dailyStats  DailyStat[]
  dailyVisitors DailyVisitor[]
  dailySessions DailySession[]
  pageStats   PageStat[]

  @@index([userId])
}

model Event {
  id          String   @id @default(cuid())

  visitorId   String
  sessionId   String

  eventType   String

  path        String
  referrer    String?

  country     String?
  browser     String?
  device      String?
  language    String?
  timezone    String?
  screenWidth Int?
  screenHeight Int?

  createdAt   DateTime @default(now())
  lastActiveAt DateTime?

  websiteId   String
  website     Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([websiteId, lastActiveAt])
  @@index([websiteId, createdAt])
  @@index([websiteId, visitorId])
  @@index([websiteId, sessionId])
  @@index([createdAt])
}

model DailyStat {
  id          String   @id @default(cuid())

  date        DateTime

  pageviews   Int      @default(0)
  visitors    Int      @default(0)
  sessions    Int      @default(0)

  websiteId   String
  website     Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([date])
  @@index([websiteId, date])
  @@unique([websiteId, date])
}

model DailyVisitor {
  id          String   @id @default(cuid())

  date        DateTime
  visitorId   String

  websiteId   String
  website     Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([date])
  @@index([websiteId, date])
  @@unique([websiteId, date, visitorId])
}

model DailySession {
  id          String   @id @default(cuid())

  date        DateTime
  sessionId   String

  websiteId   String
  website     Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([date])
  @@index([websiteId, date])
  @@unique([websiteId, date, sessionId])
}


model PageStat {
  id          String   @id @default(cuid())

  path        String
  views       Int      @default(0)

  websiteId   String
  website     Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([path])
  @@index([websiteId, views])
  @@unique([websiteId, path])
}


model Subscription {
  id          String   @id @default(cuid())

  plan        String
  status      String

  paddleCustomerId String?
  paddleSubscriptionId String?
  paddlePriceId String?

  currentPeriodEnd DateTime?

  createdAt   DateTime @default(now())

  userId      String   @unique

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
